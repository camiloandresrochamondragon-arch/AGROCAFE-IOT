# Copia este archivo como .env y ajusta los valores

# Clave secreta para sesiones Flask (cámbiala por una cadena aleatoria larga)
SECRET_KEY=cambia-esta-clave-por-una-muy-segura-y-larga

# URL de la base de datos
# SQLite (desarrollo, ya viene configurado):
DATABASE_URL=sqlite:///agrocafe.db

# MySQL (producción):
# DATABASE_URL=mysql+pymysql://usuario:contraseña@localhost/agrocafe_db

# PostgreSQL (producción):
# DATABASE_URL=postgresql://usuario:contraseña@localhost/agrocafe_db

FLASK_ENV=development
